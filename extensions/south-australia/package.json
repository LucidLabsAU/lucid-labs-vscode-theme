{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "south-australia-theme",
  "displayName": "South Australia",
  "description": "A professional theme for Visual Studio Code featuring South Australia's iconic blue and red colour palette.",
  "version": "1.8.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "south australia",
    "sa",
    "blue",
    "red",
    "professional",
    "australian",
    "adelaide",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0A0C18",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "South Australia Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/south-australia-dark.json"
      },
      {
        "label": "South Australia Light",
        "uiTheme": "vs",
        "path": "./themes/south-australia-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "south-australia-icons",
        "label": "South Australia Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "southAustraliaThemeContainer",
          "title": "South Australia",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "southAustraliaThemeContainer": [
        {
          "id": "southAustraliaThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "South Australia"
        }
      ]
    },
    "commands": [
      {
        "command": "southAustraliaTheme.switchDark",
        "title": "Switch to South Australia Dark",
        "category": "South Australia"
      },
      {
        "command": "southAustraliaTheme.switchLight",
        "title": "Switch to South Australia Light",
        "category": "South Australia"
      },
      {
        "command": "southAustraliaTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "South Australia"
      },
      {
        "command": "southAustraliaTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "South Australia",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "South Australia Theme",
      "properties": {
        "southAustraliaTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the South Australia brand chip in the status bar while a South Australia theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "southAustraliaTheme.openAbout",
          "when": "view == southAustraliaThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.sa.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
