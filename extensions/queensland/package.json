{
  "name": "queensland-theme",
  "displayName": "Queensland",
  "description": "A professional theme for Visual Studio Code featuring Queensland's iconic blue colour palette with the Queensland Coat of Arms.",
  "version": "1.8.2",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "queensland",
    "qld",
    "blue",
    "professional",
    "australian",
    "brisbane",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0A1929",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Queensland Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/queensland-dark.json"
      },
      {
        "label": "Queensland Light",
        "uiTheme": "vs",
        "path": "./themes/queensland-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "queensland-icons",
        "label": "Queensland Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "queenslandThemeContainer",
          "title": "Queensland",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "queenslandThemeContainer": [
        {
          "id": "queenslandThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Queensland"
        }
      ]
    },
    "commands": [
      {
        "command": "queenslandTheme.switchDark",
        "title": "Switch to Queensland Dark",
        "category": "Queensland"
      },
      {
        "command": "queenslandTheme.switchLight",
        "title": "Switch to Queensland Light",
        "category": "Queensland"
      },
      {
        "command": "queenslandTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Queensland"
      },
      {
        "command": "queenslandTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Queensland",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Queensland Theme",
      "properties": {
        "queenslandTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Queensland brand chip in the status bar while a Queensland theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "queenslandTheme.openAbout",
          "when": "view == queenslandThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.qld.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
