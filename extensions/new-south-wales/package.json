{
  "name": "new-south-wales-theme",
  "displayName": "New South Wales",
  "description": "A professional theme for Visual Studio Code featuring New South Wales' iconic blue and waratah red colour palette.",
  "version": "1.7.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "new south wales",
    "nsw",
    "blue",
    "waratah",
    "professional",
    "australian",
    "sydney",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0D0E14",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "New South Wales Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/new-south-wales-dark.json"
      },
      {
        "label": "New South Wales Light",
        "uiTheme": "vs",
        "path": "./themes/new-south-wales-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "new-south-wales-icons",
        "label": "New South Wales Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "newSouthWalesThemeContainer",
          "title": "New South Wales",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "newSouthWalesThemeContainer": [
        {
          "id": "newSouthWalesThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "New South Wales"
        }
      ]
    },
    "commands": [
      {
        "command": "newSouthWalesTheme.switchDark",
        "title": "Switch to New South Wales Dark",
        "category": "New South Wales"
      },
      {
        "command": "newSouthWalesTheme.switchLight",
        "title": "Switch to New South Wales Light",
        "category": "New South Wales"
      },
      {
        "command": "newSouthWalesTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "New South Wales"
      },
      {
        "command": "newSouthWalesTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "New South Wales",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "New South Wales Theme",
      "properties": {
        "newSouthWalesTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the New South Wales brand chip in the status bar while a New South Wales theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "newSouthWalesTheme.openAbout",
          "when": "view == newSouthWalesThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.nsw.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
