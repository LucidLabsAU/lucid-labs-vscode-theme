{
  "name": "act-theme",
  "displayName": "ACT Theme",
  "description": "A professional theme for Visual Studio Code featuring the Australian Capital Territory's iconic blue and gold colour palette.",
  "version": "1.6.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "act",
    "australian capital territory",
    "blue",
    "gold",
    "professional",
    "australian",
    "canberra",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0A0C18",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "ACT Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/act-dark.json"
      },
      {
        "label": "ACT Light",
        "uiTheme": "vs",
        "path": "./themes/act-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "act-icons",
        "label": "ACT Icons",
        "path": "./icon-theme.json"
      }
    ]
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
