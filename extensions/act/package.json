{
  "name": "act-theme",
  "displayName": "ACT Theme",
  "description": "A professional theme for Visual Studio Code featuring the Australian Capital Territory's iconic blue and gold colour palette.",
  "version": "1.7.1",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "act",
    "australian capital territory",
    "blue",
    "gold",
    "professional",
    "australian",
    "canberra",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0A0C18",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "ACT Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/act-dark.json"
      },
      {
        "label": "ACT Light",
        "uiTheme": "vs",
        "path": "./themes/act-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "act-icons",
        "label": "ACT Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "actThemeContainer",
          "title": "ACT",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "actThemeContainer": [
        {
          "id": "actThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "ACT"
        }
      ]
    },
    "commands": [
      {
        "command": "actTheme.switchDark",
        "title": "Switch to ACT Dark",
        "category": "ACT"
      },
      {
        "command": "actTheme.switchLight",
        "title": "Switch to ACT Light",
        "category": "ACT"
      },
      {
        "command": "actTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "ACT"
      },
      {
        "command": "actTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "ACT",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "ACT Theme",
      "properties": {
        "actTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the ACT brand chip in the status bar while a ACT theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "actTheme.openAbout",
          "when": "view == actThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.act.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
