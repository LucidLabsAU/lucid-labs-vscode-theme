{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "ai-tour-sydney-theme",
  "displayName": "AI Tour Sydney",
  "version": "1.4.0",
  "description": "A modern, premium dark theme inspired by the AI Tour Sydney 20-24 April 2026 event",
  "publisher": "lucidlabs",
  "icon": "icon.png",
  "license": "MIT",
  "homepage": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "keywords": [
    "theme",
    "dark theme",
    "colour theme",
    "ai tour",
    "sydney",
    "blue",
    "cyan",
    "modern",
    "premium"
  ],
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "contributes": {
    "themes": [
      {
        "label": "AI Tour Sydney Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/ai-tour-sydney-dark.json"
      },
      {
        "label": "AI Tour Sydney Light",
        "uiTheme": "vs",
        "path": "./themes/ai-tour-sydney-light.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiTourSydneyThemeContainer",
          "title": "AI Tour Sydney",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "aiTourSydneyThemeContainer": [
        {
          "id": "aiTourSydneyThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "AI Tour Sydney"
        }
      ]
    },
    "commands": [
      {
        "command": "aiTourSydneyTheme.switchDark",
        "title": "Switch to AI Tour Sydney Dark",
        "category": "AI Tour Sydney"
      },
      {
        "command": "aiTourSydneyTheme.switchLight",
        "title": "Switch to AI Tour Sydney Light",
        "category": "AI Tour Sydney"
      },
      {
        "command": "aiTourSydneyTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "AI Tour Sydney"
      },
      {
        "command": "aiTourSydneyTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "AI Tour Sydney",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "AI Tour Sydney Theme",
      "properties": {
        "aiTourSydneyTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the AI Tour Sydney brand chip in the status bar while a AI Tour Sydney theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "aiTourSydneyTheme.openAbout",
          "when": "view == aiTourSydneyThemePalette",
          "group": "navigation"
        }
      ]
    },
    "iconThemes": [
      {
        "id": "ai-tour-sydney-icons",
        "label": "AI Tour Sydney Icons",
        "path": "./icon-theme.json"
      }
    ]
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "galleryBanner": {
    "color": "#0F2E74",
    "theme": "dark"
  },
  "qna": "marketplace"
}
