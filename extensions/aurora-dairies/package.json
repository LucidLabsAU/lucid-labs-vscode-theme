{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "aurora-dairies-theme",
  "displayName": "Aurora Dairies",
  "description": "A calm, modern VS Code colour theme inspired by Aurora Dairies — deep aurora-blue surfaces, cream foreground and pasture-green syntax accents, evoking dawn over pasture-based dairy farms.",
  "version": "1.1.3",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "aurora",
    "aurora dairies",
    "dairy",
    "agriculture",
    "agribusiness",
    "blue",
    "cream",
    "australia",
    "new zealand",
    "brand",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0C1A33",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Aurora Dairies Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/aurora-dairies-dark.json"
      },
      {
        "label": "Aurora Dairies Light",
        "uiTheme": "vs",
        "path": "./themes/aurora-dairies-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "aurora-dairies-icons",
        "label": "Aurora Dairies Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "auroraDairiesThemeContainer",
          "title": "Aurora Dairies",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "auroraDairiesThemeContainer": [
        {
          "id": "auroraDairiesThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Aurora Dairies"
        }
      ]
    },
    "commands": [
      {
        "command": "auroraDairiesTheme.switchDark",
        "title": "Switch to Aurora Dairies Dark",
        "category": "Aurora Dairies"
      },
      {
        "command": "auroraDairiesTheme.switchLight",
        "title": "Switch to Aurora Dairies Light",
        "category": "Aurora Dairies"
      },
      {
        "command": "auroraDairiesTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Aurora Dairies"
      },
      {
        "command": "auroraDairiesTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Aurora Dairies",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Aurora Dairies Theme",
      "properties": {
        "auroraDairiesTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Aurora Dairies brand chip in the status bar while a Aurora Dairies theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "auroraDairiesTheme.openAbout",
          "when": "view == auroraDairiesThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://auroradairies.com.au",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
