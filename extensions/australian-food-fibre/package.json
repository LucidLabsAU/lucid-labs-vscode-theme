{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "australian-food-fibre-theme",
  "displayName": "Australian Food & Fibre",
  "description": "A professional VS Code colour theme inspired by Australian Food & Fibre (AFF) — deep navy backgrounds with gold accents, evoking Australian cotton fields and agricultural excellence.",
  "version": "1.9.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "australian food fibre",
    "aff",
    "cotton",
    "agriculture",
    "navy",
    "gold",
    "professional",
    "brand",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0E1826",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "AFF Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/australian-food-fibre-dark.json"
      },
      {
        "label": "AFF Light",
        "uiTheme": "vs",
        "path": "./themes/australian-food-fibre-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "australian-food-fibre-icons",
        "label": "Australian Food & Fibre Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "australianFoodFibreThemeContainer",
          "title": "Australian Food & Fibre",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "australianFoodFibreThemeContainer": [
        {
          "id": "australianFoodFibreThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Australian Food & Fibre"
        }
      ]
    },
    "commands": [
      {
        "command": "australianFoodFibreTheme.switchDark",
        "title": "Switch to Australian Food & Fibre Dark",
        "category": "Australian Food & Fibre"
      },
      {
        "command": "australianFoodFibreTheme.switchLight",
        "title": "Switch to Australian Food & Fibre Light",
        "category": "Australian Food & Fibre"
      },
      {
        "command": "australianFoodFibreTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Australian Food & Fibre"
      },
      {
        "command": "australianFoodFibreTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Australian Food & Fibre",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Australian Food & Fibre Theme",
      "properties": {
        "australianFoodFibreTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Australian Food & Fibre brand chip in the status bar while a Australian Food & Fibre theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "australianFoodFibreTheme.openAbout",
          "when": "view == australianFoodFibreThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://australianfoodandfibre.com.au",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
