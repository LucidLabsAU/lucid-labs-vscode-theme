{
  "name": "banjo-loans-theme",
  "displayName": "Banjo Loans",
  "description": "A bold VS Code colour theme featuring electric blue accents and deep purple backgrounds, inspired by the Banjo Loans visual identity. Built and published by Lucid Labs on behalf of Banjo Loans. All trademarks belong to their respective owners.",
  "version": "1.7.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "banjo",
    "banjo loans",
    "fintech",
    "finance",
    "blue",
    "purple",
    "professional",
    "brand",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1A1024",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Banjo Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/banjo-loans-dark.json"
      },
      {
        "label": "Banjo Light",
        "uiTheme": "vs",
        "path": "./themes/banjo-loans-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "banjo-loans-icons",
        "label": "Banjo Loans Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "banjoLoansThemeContainer",
          "title": "Banjo Loans",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "banjoLoansThemeContainer": [
        {
          "id": "banjoLoansThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Banjo Loans"
        }
      ]
    },
    "commands": [
      {
        "command": "banjoLoansTheme.switchDark",
        "title": "Switch to Banjo Loans Dark",
        "category": "Banjo Loans"
      },
      {
        "command": "banjoLoansTheme.switchLight",
        "title": "Switch to Banjo Loans Light",
        "category": "Banjo Loans"
      },
      {
        "command": "banjoLoansTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Banjo Loans"
      },
      {
        "command": "banjoLoansTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Banjo Loans",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Banjo Loans Theme",
      "properties": {
        "banjoLoansTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Banjo Loans brand chip in the status bar while a Banjo Loans theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "banjoLoansTheme.openAbout",
          "when": "view == banjoLoansThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://banjoloans.com",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
