{
  "name": "tasmania-theme",
  "displayName": "Tasmania",
  "description": "A professional theme for Visual Studio Code featuring Tasmania's iconic blue and forest green colour palette.",
  "version": "1.6.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "tasmania",
    "tas",
    "blue",
    "green",
    "professional",
    "australian",
    "hobart",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0B1218",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Tasmania Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/tasmania-dark.json"
      },
      {
        "label": "Tasmania Light",
        "uiTheme": "vs",
        "path": "./themes/tasmania-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "tasmania-icons",
        "label": "Tasmania Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tasmaniaThemeContainer",
          "title": "Tasmania",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "tasmaniaThemeContainer": [
        {
          "id": "tasmaniaThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Tasmania"
        }
      ]
    },
    "commands": [
      {
        "command": "tasmaniaTheme.switchDark",
        "title": "Switch to Tasmania Dark",
        "category": "Tasmania"
      },
      {
        "command": "tasmaniaTheme.switchLight",
        "title": "Switch to Tasmania Light",
        "category": "Tasmania"
      },
      {
        "command": "tasmaniaTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Tasmania"
      },
      {
        "command": "tasmaniaTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Tasmania",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Tasmania Theme",
      "properties": {
        "tasmaniaTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Tasmania brand chip in the status bar while a Tasmania theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "tasmaniaTheme.openAbout",
          "when": "view == tasmaniaThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.tas.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
