{
  "name": "pax8-beyond-2026-copenhagen-theme",
  "displayName": "Pax8 Beyond 2026 Copenhagen",
  "description": "A bold, red-forward VS Code colour theme for Pax8 Beyond 2026 Copenhagen (EMEA) — Community Red leading, with Education Yellow and Innovation Blue on black. Built and published by Lucid Labs on behalf of Pax8. All trademarks belong to their respective owners.",
  "version": "1.0.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "pax8",
    "pax8 beyond",
    "beyond 2026",
    "copenhagen",
    "emea",
    "europe",
    "conference",
    "event",
    "red",
    "yellow",
    "blue",
    "black",
    "brand",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Pax8 Beyond 2026 Copenhagen Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/pax8-beyond-2026-copenhagen-dark.json"
      },
      {
        "label": "Pax8 Beyond 2026 Copenhagen Light",
        "uiTheme": "vs",
        "path": "./themes/pax8-beyond-2026-copenhagen-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "pax8-beyond-2026-copenhagen-icons",
        "label": "Pax8 Beyond 2026 Copenhagen Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pax8Beyond2026CopenhagenThemeContainer",
          "title": "Pax8 Beyond 2026 Copenhagen",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "pax8Beyond2026CopenhagenThemeContainer": [
        {
          "id": "pax8Beyond2026CopenhagenThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Pax8 Beyond 2026 Copenhagen"
        }
      ]
    },
    "commands": [
      {
        "command": "pax8Beyond2026CopenhagenTheme.switchDark",
        "title": "Switch to Pax8 Beyond 2026 Copenhagen Dark",
        "category": "Pax8 Beyond 2026 Copenhagen"
      },
      {
        "command": "pax8Beyond2026CopenhagenTheme.switchLight",
        "title": "Switch to Pax8 Beyond 2026 Copenhagen Light",
        "category": "Pax8 Beyond 2026 Copenhagen"
      },
      {
        "command": "pax8Beyond2026CopenhagenTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Pax8 Beyond 2026 Copenhagen"
      },
      {
        "command": "pax8Beyond2026CopenhagenTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Pax8 Beyond 2026 Copenhagen",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Pax8 Beyond 2026 Copenhagen Theme",
      "properties": {
        "pax8Beyond2026CopenhagenTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Pax8 Beyond 2026 Copenhagen brand chip in the status bar while a Pax8 Beyond 2026 Copenhagen theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "pax8Beyond2026CopenhagenTheme.openAbout",
          "when": "view == pax8Beyond2026CopenhagenThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.pax8beyond.com/emea/",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
