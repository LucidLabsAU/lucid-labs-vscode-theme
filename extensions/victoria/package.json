{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "victoria-theme",
  "displayName": "Victoria",
  "description": "A professional theme for Visual Studio Code featuring Victoria's iconic blue and navy colour palette.",
  "version": "1.8.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "victoria",
    "vic",
    "blue",
    "navy",
    "professional",
    "australian",
    "melbourne",
    "brand",
    "dark mode",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0C0E18",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Victoria Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/victoria-dark.json"
      },
      {
        "label": "Victoria Light",
        "uiTheme": "vs",
        "path": "./themes/victoria-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "victoria-icons",
        "label": "Victoria Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "victoriaThemeContainer",
          "title": "Victoria",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "victoriaThemeContainer": [
        {
          "id": "victoriaThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Victoria"
        }
      ]
    },
    "commands": [
      {
        "command": "victoriaTheme.switchDark",
        "title": "Switch to Victoria Dark",
        "category": "Victoria"
      },
      {
        "command": "victoriaTheme.switchLight",
        "title": "Switch to Victoria Light",
        "category": "Victoria"
      },
      {
        "command": "victoriaTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Victoria"
      },
      {
        "command": "victoriaTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Victoria",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Victoria Theme",
      "properties": {
        "victoriaTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Victoria brand chip in the status bar while a Victoria theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "victoriaTheme.openAbout",
          "when": "view == victoriaThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.vic.gov.au",
  "sponsor": {
    "url": "https://lucidlabs.com.au"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
