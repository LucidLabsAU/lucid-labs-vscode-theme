{
  "name": "perfection-fresh-theme",
  "displayName": "Perfection Fresh",
  "description": "A vibrant VS Code colour theme featuring red seal accents and fresh produce greens, inspired by the Perfection Fresh Australia visual identity. Built and published by Lucid Labs on behalf of Perfection Fresh. All trademarks belong to their respective owners.",
  "version": "1.8.1",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "perfection",
    "perfection fresh",
    "fresh produce",
    "agriculture",
    "red",
    "green",
    "brand",
    "australia",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#141414",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Perfection Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/perfection-fresh-dark.json"
      },
      {
        "label": "Perfection Light",
        "uiTheme": "vs",
        "path": "./themes/perfection-fresh-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "perfection-fresh-icons",
        "label": "Perfection Fresh Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "perfectionFreshThemeContainer",
          "title": "Perfection Fresh",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "perfectionFreshThemeContainer": [
        {
          "id": "perfectionFreshThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "Perfection Fresh"
        }
      ]
    },
    "commands": [
      {
        "command": "perfectionFreshTheme.switchDark",
        "title": "Switch to Perfection Fresh Dark",
        "category": "Perfection Fresh"
      },
      {
        "command": "perfectionFreshTheme.switchLight",
        "title": "Switch to Perfection Fresh Light",
        "category": "Perfection Fresh"
      },
      {
        "command": "perfectionFreshTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "Perfection Fresh"
      },
      {
        "command": "perfectionFreshTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "Perfection Fresh",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "Perfection Fresh Theme",
      "properties": {
        "perfectionFreshTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the Perfection Fresh brand chip in the status bar while a Perfection Fresh theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "perfectionFreshTheme.openAbout",
          "when": "view == perfectionFreshThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://www.perfection.com.au",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
