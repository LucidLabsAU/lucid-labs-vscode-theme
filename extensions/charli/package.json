{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "charli-health-theme",
  "displayName": "CHARLI Health",
  "description": "A warm, accessible VS Code colour theme featuring Taffy pink, Blueberry blue, and Jungle green, inspired by the CHARLI Health visual identity.",
  "version": "1.10.0",
  "publisher": "lucidlabs",
  "license": "MIT",
  "icon": "icon.png",
  "author": {
    "name": "Lucid Labs",
    "url": "https://lucidlabs.com.au"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "colour theme",
    "charli",
    "charli health",
    "healthcare",
    "warm",
    "accessible",
    "pink",
    "pastel",
    "brand",
    "icon theme",
    "icons"
  ],
  "categories": [
    "Themes",
    "Other"
  ],
  "galleryBanner": {
    "color": "#1E1A24",
    "theme": "dark"
  },
  "qna": "marketplace",
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "themes": [
      {
        "label": "CHARLI Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/charli-dark.json"
      },
      {
        "label": "CHARLI Light",
        "uiTheme": "vs",
        "path": "./themes/charli-light.json"
      }
    ],
    "iconThemes": [
      {
        "id": "charli-health-icons",
        "label": "CHARLI Health Icons",
        "path": "./icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "charliThemeContainer",
          "title": "CHARLI Health",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "charliThemeContainer": [
        {
          "id": "charliThemePalette",
          "name": "Brand Palette",
          "type": "webview",
          "icon": "activity-icon.svg",
          "contextualTitle": "CHARLI Health"
        }
      ]
    },
    "commands": [
      {
        "command": "charliTheme.switchDark",
        "title": "Switch to CHARLI Health Dark",
        "category": "CHARLI Health"
      },
      {
        "command": "charliTheme.switchLight",
        "title": "Switch to CHARLI Health Light",
        "category": "CHARLI Health"
      },
      {
        "command": "charliTheme.toggleVariant",
        "title": "Toggle Dark/Light Variant",
        "category": "CHARLI Health"
      },
      {
        "command": "charliTheme.openAbout",
        "title": "Open Brand Palette",
        "category": "CHARLI Health",
        "icon": "$(symbol-color)"
      }
    ],
    "configuration": {
      "title": "CHARLI Health Theme",
      "properties": {
        "charliTheme.showStatusBarItem": {
          "type": "boolean",
          "default": true,
          "description": "Show the CHARLI Health brand chip in the status bar while a CHARLI Health theme is active."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "charliTheme.openAbout",
          "when": "view == charliThemePalette",
          "group": "navigation"
        }
      ]
    }
  },
  "engines": {
    "vscode": "^1.107.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme.git"
  },
  "bugs": {
    "url": "https://github.com/LucidLabsAU/lucid-labs-vscode-theme/issues"
  },
  "homepage": "https://charli.health",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ]
}
