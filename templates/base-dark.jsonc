// Base dark theme template
// Placeholders: {{role}} resolves to brand colour, {{role}}XX appends hex alpha
//
// Colour derivation strategy (no new brand.json keys needed):
//   Core roles: background, foreground, accent, keyword, string, constant,
//               function, error, success, warning, info, muted, comment,
//               modified, added, shadow, plus terminal.* and bracket* colours
//   Everything else derives from these via alpha suffixes and fallback chains.
//
//   Surfaces:    background → backgroundDeep → backgroundPanel → backgroundElevated → backgroundInput → backgroundHover
//   Borders:     accent + alpha (20-50) for subtle, accent solid for focus
//   States:      error/warning/info/success with alpha for backgrounds
//   Git/diff:    added(success), modified(function/keyword), error for deleted
//   Brackets:    bracket1-6 cycle through accent/keyword/warning/success/magenta/string
{
  "type": "dark",
  "colors": {
    // ─── Contrast (high contrast themes only, transparent by default) ──
    "contrastActiveBorder": "{{accent}}00",
    "contrastBorder": "{{accent}}00",

    // ─── Editor ───────────────────────────────────────────────
    "editor.background": "{{background}}",
    "editor.foreground": "{{foreground}}",
    "editorCursor.foreground": "{{accent}}",
    "editorCursor.background": "{{background}}",
    "editor.lineHighlightBackground": "{{backgroundInput}}",
    "editor.lineHighlightBorder": "{{accent}}15",
    "editor.inactiveLineHighlightBackground": "{{backgroundInput}}80",
    "editor.selectionBackground": "{{accent}}50",
    "editor.selectionForeground": "{{foreground}}",
    "editor.inactiveSelectionBackground": "{{accent}}30",
    "editor.selectionHighlightBackground": "{{accent}}30",
    "editor.selectionHighlightBorder": "{{accent}}50",
    "editor.findMatchBackground": "{{findMatch|accent}}80",
    "editor.findMatchForeground": "{{foreground}}",
    "editor.findMatchHighlightBackground": "{{findMatch|accent}}50",
    "editor.findMatchHighlightForeground": "{{foreground}}",
    "editor.findRangeHighlightBackground": "{{accent}}20",
    "editor.findMatchBorder": "{{findMatch|accent}}",
    "editor.findMatchHighlightBorder": "{{findMatch|accent}}80",
    "editor.findRangeHighlightBorder": "{{accent}}00",
    "editor.hoverHighlightBackground": "{{accent}}25",
    "editor.wordHighlightBackground": "{{accent}}30",
    "editor.wordHighlightBorder": "{{accent}}50",
    "editor.wordHighlightStrongBackground": "{{accent}}50",
    "editor.wordHighlightStrongBorder": "{{accent}}80",
    "editor.wordHighlightTextBackground": "{{accent}}20",
    "editor.wordHighlightTextBorder": "{{accent}}40",
    "editor.rangeHighlightBackground": "{{accent}}15",
    "editor.rangeHighlightBorder": "{{accent}}00",
    "editor.symbolHighlightBackground": "{{accent}}30",
    "editor.symbolHighlightBorder": "{{accent}}50",
    "editor.linkedEditingBackground": "{{accent}}30",
    "editor.foldBackground": "{{accent}}15",
    "editor.foldPlaceholderForeground": "{{muted}}80",
    "editor.placeholder.foreground": "{{muted}}80",
    "editor.compositionBorder": "{{accent}}",
    "editorSnippetTabstopHighlightBackground": "{{accent}}30",
    "editorSnippetTabstopHighlightBorder": "{{accent}}00",
    "editorSnippetFinalTabstopHighlightBackground": "{{success}}30",
    "editorSnippetFinalTabstopHighlightBorder": "{{success}}00",
    "editor.stackFrameHighlightBackground": "{{warning}}30",
    "editor.focusedStackFrameHighlightBackground": "{{success}}30",
    "editor.inlineValuesForeground": "{{muted}}CC",
    "editor.inlineValuesBackground": "{{accent}}15",

    // Line numbers
    "editorLineNumber.foreground": "{{lineNumber|keyword}}",
    "editorLineNumber.activeForeground": "{{accent}}",
    "editorLineNumber.dimmedForeground": "{{muted}}50",

    // Multi-cursor
    "editorMultiCursor.primary.foreground": "{{accent}}",
    "editorMultiCursor.primary.background": "{{background}}",
    "editorMultiCursor.secondary.foreground": "{{keyword}}",
    "editorMultiCursor.secondary.background": "{{background}}",

    // Indent guides & whitespace
    "editorIndentGuide.background1": "{{bracket1}}25",
    "editorIndentGuide.background2": "{{bracket2}}25",
    "editorIndentGuide.background3": "{{bracket3}}25",
    "editorIndentGuide.background4": "{{bracket4}}25",
    "editorIndentGuide.background5": "{{bracket5}}25",
    "editorIndentGuide.background6": "{{bracket6}}25",
    "editorIndentGuide.activeBackground1": "{{bracket1}}",
    "editorIndentGuide.activeBackground2": "{{bracket2}}",
    "editorIndentGuide.activeBackground3": "{{bracket3}}",
    "editorIndentGuide.activeBackground4": "{{bracket4}}",
    "editorIndentGuide.activeBackground5": "{{bracket5}}",
    "editorIndentGuide.activeBackground6": "{{bracket6}}",
    "editorWhitespace.foreground": "{{indentGuide|keyword}}50",
    "editorRuler.foreground": "{{indentGuide|keyword}}30",

    // Unicode highlight
    "editorUnicodeHighlight.border": "{{warning}}",
    "editorUnicodeHighlight.background": "{{warning}}20",

    // Links
    "editorLink.activeForeground": "{{accent}}",

    // Code lens & lightbulb
    "editorCodeLens.foreground": "{{muted}}80",
    "editorLightBulb.foreground": "{{warning}}",
    "editorLightBulbAutoFix.foreground": "{{success}}",
    "editorLightBulbAi.foreground": "{{accent}}",

    // ─── Bracket pairs ───────────────────────────────────────
    "editorBracketMatch.border": "{{accent}}80",
    "editorBracketHighlight.foreground1": "{{bracket1}}",
    "editorBracketHighlight.foreground2": "{{bracket2}}",
    "editorBracketHighlight.foreground3": "{{bracket3}}",
    "editorBracketHighlight.foreground4": "{{bracket4}}",
    "editorBracketHighlight.foreground5": "{{bracket5}}",
    "editorBracketHighlight.foreground6": "{{bracket6}}",
    "editorBracketHighlight.unexpectedBracket.foreground": "{{error}}",
    "editorBracketPairGuide.activeBackground1": "{{bracket1}}80",
    "editorBracketPairGuide.activeBackground2": "{{bracket2}}80",
    "editorBracketPairGuide.activeBackground3": "{{bracket3}}80",
    "editorBracketPairGuide.activeBackground4": "{{bracket4}}80",
    "editorBracketPairGuide.activeBackground5": "{{bracket5}}80",
    "editorBracketPairGuide.activeBackground6": "{{bracket6}}80",
    "editorBracketPairGuide.background1": "{{bracket1}}40",
    "editorBracketPairGuide.background2": "{{bracket2}}40",
    "editorBracketPairGuide.background3": "{{bracket3}}40",
    "editorBracketPairGuide.background4": "{{bracket4}}40",
    "editorBracketPairGuide.background5": "{{bracket5}}40",
    "editorBracketPairGuide.background6": "{{bracket6}}40",

    // ─── Diagnostics ─────────────────────────────────────────
    "editorError.foreground": "{{error}}",
    "editorError.border": "{{error}}00",
    "editorError.background": "{{error}}15",
    "editorWarning.foreground": "{{warning}}",
    "editorWarning.border": "{{warning}}00",
    "editorWarning.background": "{{warning}}15",
    "editorInfo.foreground": "{{info}}",
    "editorInfo.border": "{{info}}00",
    "editorInfo.background": "{{info}}15",
    "editorHint.foreground": "{{success}}",
    "editorHint.border": "{{success}}00",
    "problemsErrorIcon.foreground": "{{error}}",
    "problemsWarningIcon.foreground": "{{warning}}",
    "problemsInfoIcon.foreground": "{{info}}",
    "editorUnnecessaryCode.border": "{{muted}}50",
    "editorUnnecessaryCode.opacity": "#000000AA",

    // ─── Editor gutter ───────────────────────────────────────
    "editorGutter.background": "{{background}}",
    "editorGutter.modifiedBackground": "{{modified|function}}",
    "editorGutter.addedBackground": "{{added|success}}",
    "editorGutter.deletedBackground": "{{error}}",
    "editorGutter.commentRangeForeground": "{{muted}}50",
    "editorGutter.commentGlyphForeground": "{{accent}}",
    "editorGutter.commentUnresolvedGlyphForeground": "{{warning}}",
    "editorGutter.modifiedSecondaryBackground": "{{modified|function}}80",
    "editorGutter.addedSecondaryBackground": "{{added|success}}80",
    "editorGutter.deletedSecondaryBackground": "{{error}}80",
    "editorGutter.foldingControlForeground": "{{muted}}80",
    "editorGutter.itemBackground": "{{backgroundPanel}}",
    "editorGutter.itemGlyphForeground": "{{accent}}",
    "editorGutter.commentDraftGlyphForeground": "{{accent}}80",

    // ─── Sticky scroll ───────────────────────────────────────
    "editorStickyScroll.background": "{{backgroundPanel}}",
    "editorStickyScroll.border": "{{accent}}20",
    "editorStickyScroll.shadow": "{{shadow}}30",
    "editorStickyScrollHover.background": "{{backgroundHover}}",

    // ─── Comments widget ─────────────────────────────────────
    "editorCommentsWidget.resolvedBorder": "{{success}}50",
    "editorCommentsWidget.unresolvedBorder": "{{warning}}",
    "editorCommentsWidget.rangeBackground": "{{accent}}10",
    "editorCommentsWidget.rangeActiveBackground": "{{accent}}20",
    "editorCommentsWidget.replyInputBackground": "{{backgroundInput}}",

    // ─── Inline edit ─────────────────────────────────────────
    "inlineEdit.modifiedBackground": "{{modified|function}}15",
    "inlineEdit.modifiedChangedLineBackground": "{{modified|function}}20",
    "inlineEdit.modifiedChangedTextBackground": "{{modified|function}}30",
    "inlineEdit.originalBackground": "{{error}}10",
    "inlineEdit.originalChangedLineBackground": "{{error}}15",
    "inlineEdit.originalChangedTextBackground": "{{error}}25",
    "inlineEdit.modifiedBorder": "{{modified|function}}50",
    "inlineEdit.originalBorder": "{{error}}30",
    "inlineEdit.tabWillAcceptModifiedBorder": "{{success}}80",
    "inlineEdit.tabWillAcceptOriginalBorder": "{{error}}50",
    "inlineEdit.gutterIndicator.background": "{{backgroundPanel}}",
    "inlineEdit.gutterIndicator.primaryBorder": "{{accent}}",
    "inlineEdit.gutterIndicator.primaryForeground": "{{accent}}",
    "inlineEdit.gutterIndicator.primaryBackground": "{{accent}}20",
    "inlineEdit.gutterIndicator.secondaryBorder": "{{keyword}}",
    "inlineEdit.gutterIndicator.secondaryForeground": "{{keyword}}",
    "inlineEdit.gutterIndicator.secondaryBackground": "{{keyword}}20",
    "inlineEdit.gutterIndicator.successfulBorder": "{{success}}",
    "inlineEdit.gutterIndicator.successfulForeground": "{{success}}",
    "inlineEdit.gutterIndicator.successfulBackground": "{{success}}20",

    // ─── Search editor ───────────────────────────────────────
    "search.resultsInfoForeground": "{{muted}}",
    "searchEditor.findMatchBackground": "{{accent}}40",
    "searchEditor.findMatchBorder": "{{accent}}80",
    "searchEditor.textInputBorder": "{{accent}}50",

    // ─── Activity bar ────────────────────────────────────────
    "activityBar.background": "{{backgroundDeep}}",
    "activityBar.foreground": "{{foreground}}",
    "activityBar.inactiveForeground": "{{muted}}80",
    "activityBar.border": "{{backgroundDeep}}",
    "activityBar.activeBorder": "{{accent}}",
    "activityBar.activeBackground": "{{background}}50",
    "activityBar.activeFocusBorder": "{{accent}}",
    "activityBar.dropBorder": "{{accent}}",
    "activityBarBadge.background": "{{badge|accent}}",
    "activityBarBadge.foreground": "{{foreground}}",
    "activityBarTop.foreground": "{{foreground}}",
    "activityBarTop.activeBorder": "{{accent}}",
    "activityBarTop.inactiveForeground": "{{muted}}80",
    "activityBarTop.dropBorder": "{{accent}}",
    "activityBarTop.background": "{{backgroundDeep}}",
    "activityBarTop.activeBackground": "{{background}}50",
    "activityWarningBadge.foreground": "{{foreground}}",
    "activityWarningBadge.background": "{{warning}}",
    "activityErrorBadge.foreground": "{{foreground}}",
    "activityErrorBadge.background": "{{error}}",

    // ─── Profiles ────────────────────────────────────────────
    "profileBadge.background": "{{accent}}",
    "profileBadge.foreground": "{{foreground}}",
    "profiles.sashBorder": "{{accent}}",

    // ─── Side bar ────────────────────────────────────────────
    "sideBar.background": "{{backgroundPanel}}",
    "sideBar.foreground": "{{foreground}}",
    "sideBar.border": "{{accent}}20",
    "sideBar.dropBackground": "{{accent}}30",
    "sideBarTitle.foreground": "{{accent}}",
    "sideBarTitle.background": "{{backgroundPanel}}",
    "sideBarTitle.border": "{{accent}}20",
    "sideBarSectionHeader.background": "{{sidebarHeaderBg|background}}80",
    "sideBarSectionHeader.foreground": "{{accent}}",
    "sideBarSectionHeader.border": "{{accent}}20",
    "sideBarActivityBarTop.border": "{{accent}}20",
    "sideBarStickyScroll.background": "{{backgroundPanel}}",
    "sideBarStickyScroll.border": "{{accent}}20",
    "sideBarStickyScroll.shadow": "{{shadow}}30",

    // ─── Lists and trees ─────────────────────────────────────
    "list.activeSelectionBackground": "{{accent}}50",
    "list.activeSelectionForeground": "{{foreground}}",
    "list.activeSelectionIconForeground": "{{foreground}}",
    "list.inactiveSelectionBackground": "{{accent}}30",
    "list.inactiveSelectionForeground": "{{foreground}}",
    "list.inactiveSelectionIconForeground": "{{foreground}}",
    "list.inactiveFocusBackground": "{{accent}}20",
    "list.hoverBackground": "{{accent}}20",
    "list.hoverForeground": "{{foreground}}",
    "list.focusBackground": "{{accent}}40",
    "list.focusForeground": "{{foreground}}",
    "list.focusHighlightForeground": "{{accent}}",
    "list.focusOutline": "{{accent}}80",
    "list.focusAndSelectionOutline": "{{accent}}",
    "list.highlightForeground": "{{accent}}",
    "list.dropBackground": "{{accent}}30",
    "list.dropBetweenBackground": "{{accent}}",
    "list.invalidItemForeground": "{{error}}",
    "list.errorForeground": "{{error}}",
    "list.warningForeground": "{{warning}}",
    "list.deemphasizedForeground": "{{muted}}80",
    "list.inactiveFocusOutline": "{{accent}}50",
    "list.filterMatchBorder": "{{accent}}80",
    "listFilterWidget.background": "{{backgroundInput}}",
    "listFilterWidget.outline": "{{accent}}",
    "listFilterWidget.noMatchesOutline": "{{error}}",
    "listFilterWidget.shadow": "{{shadow}}50",
    "tree.indentGuidesStroke": "{{accent}}40",
    "tree.inactiveIndentGuidesStroke": "{{accent}}20",
    "tree.tableColumnsBorder": "{{accent}}20",
    "tree.tableOddRowsBackground": "{{background}}50",

    // ─── Title bar ───────────────────────────────────────────
    "titleBar.activeBackground": "{{titleBarBg|backgroundDeep}}",
    "titleBar.activeForeground": "{{titleBarFg|foreground}}",
    "titleBar.inactiveBackground": "{{titleBarBg|backgroundDeep}}",
    "titleBar.inactiveForeground": "{{titleBarFg|muted}}80",
    "titleBar.border": "{{titleBarBorder|titleBarBg|backgroundDeep}}",

    // ─── Command centre ──────────────────────────────────────
    "commandCenter.foreground": "{{titleBarFg|foreground}}",
    "commandCenter.activeForeground": "{{titleBarFg|foreground}}",
    "commandCenter.background": "{{titleBarFg|foreground}}15",
    "commandCenter.activeBackground": "{{titleBarFg|foreground}}25",
    "commandCenter.border": "{{titleBarFg|foreground}}30",
    "commandCenter.inactiveForeground": "{{titleBarFg|muted}}80",
    "commandCenter.inactiveBorder": "{{titleBarFg|foreground}}20",
    "commandCenter.activeBorder": "{{titleBarFg|foreground}}50",
    "commandCenter.debuggingBackground": "{{debuggingBg|success}}30",

    // ─── Status bar ──────────────────────────────────────────
    "statusBar.background": "{{statusBar|backgroundDeep}}",
    "statusBar.foreground": "{{statusBarFg|foreground}}",
    "statusBar.border": "{{statusBarBorder|statusBar|backgroundDeep}}",
    "statusBar.noFolderBackground": "{{statusBarBorder|statusBar|backgroundDeep}}",
    "statusBar.noFolderForeground": "{{statusBarFg|foreground}}",
    "statusBar.noFolderBorder": "{{statusBarBorder|statusBar|backgroundDeep}}",
    "statusBar.debuggingBackground": "{{debuggingBg|success}}",
    "statusBar.debuggingForeground": "{{debuggingFg|foreground}}",
    "statusBar.debuggingBorder": "{{debuggingBg|success}}80",
    "statusBar.focusBorder": "{{accent}}",
    "statusBarItem.activeBackground": "{{accent}}50",
    "statusBarItem.hoverForeground": "{{foreground}}",
    "statusBarItem.hoverBackground": "{{accent}}30",
    "statusBarItem.prominentForeground": "{{foreground}}",
    "statusBarItem.prominentBackground": "{{prominentButton|accent}}",
    "statusBarItem.prominentHoverForeground": "{{foreground}}",
    "statusBarItem.prominentHoverBackground": "{{prominentButtonHover|accentHover}}",
    "statusBarItem.remoteBackground": "{{keyword}}",
    "statusBarItem.remoteForeground": "{{remoteFg|foreground}}",
    "statusBarItem.remoteHoverBackground": "{{keyword}}CC",
    "statusBarItem.remoteHoverForeground": "{{remoteFg|foreground}}",
    "statusBarItem.errorBackground": "{{error}}",
    "statusBarItem.errorForeground": "{{foreground}}",
    "statusBarItem.errorHoverBackground": "{{error}}CC",
    "statusBarItem.errorHoverForeground": "{{foreground}}",
    "statusBarItem.warningBackground": "{{warning}}",
    "statusBarItem.warningForeground": "{{backgroundDeep}}",
    "statusBarItem.warningHoverBackground": "{{warning}}CC",
    "statusBarItem.warningHoverForeground": "{{backgroundDeep}}",
    "statusBarItem.compactHoverBackground": "{{accent}}40",
    "statusBarItem.focusBorder": "{{accent}}",
    "statusBarItem.offlineBackground": "{{muted}}80",
    "statusBarItem.offlineForeground": "{{foreground}}",
    "statusBarItem.offlineHoverForeground": "{{foreground}}",
    "statusBarItem.offlineHoverBackground": "{{muted}}60",

    // ─── Tabs ────────────────────────────────────────────────
    "tab.activeBackground": "{{background}}",
    "tab.activeForeground": "{{foreground}}",
    "tab.activeBorder": "{{accent}}",
    "tab.activeBorderTop": "{{accent}}00",
    "tab.selectedBorderTop": "{{accent}}",
    "tab.selectedBackground": "{{background}}",
    "tab.selectedForeground": "{{foreground}}",
    "tab.inactiveBackground": "{{backgroundPanel}}",
    "tab.inactiveForeground": "{{muted}}80",
    "tab.border": "{{accent}}20",
    "tab.hoverBackground": "{{tabHoverBg|background}}80",
    "tab.hoverForeground": "{{foreground}}",
    "tab.hoverBorder": "{{accent}}50",
    "tab.unfocusedActiveBackground": "{{background}}",
    "tab.unfocusedActiveForeground": "{{foreground}}CC",
    "tab.unfocusedActiveBorder": "{{accent}}80",
    "tab.unfocusedActiveBorderTop": "{{accent}}00",
    "tab.unfocusedInactiveBackground": "{{backgroundPanel}}",
    "tab.unfocusedInactiveForeground": "{{muted}}60",
    "tab.unfocusedHoverBackground": "{{tabHoverBg|background}}60",
    "tab.unfocusedHoverForeground": "{{foreground}}CC",
    "tab.unfocusedHoverBorder": "{{accent}}30",
    "tab.lastPinnedBorder": "{{accent}}40",
    "tab.activeModifiedBorder": "{{modified|function}}",
    "tab.inactiveModifiedBorder": "{{modified|function}}80",
    "tab.unfocusedActiveModifiedBorder": "{{modified|function}}CC",
    "tab.unfocusedInactiveModifiedBorder": "{{modified|function}}60",
    "tab.dragAndDropBorder": "{{accent}}",

    // ─── Editor groups ───────────────────────────────────────
    "editorGroupHeader.tabsBackground": "{{backgroundPanel}}",
    "editorGroupHeader.tabsBorder": "{{accent}}20",
    "editorGroupHeader.noTabsBackground": "{{background}}",
    "editorGroupHeader.border": "{{accent}}20",
    "editorGroup.border": "{{accent}}20",
    "editorGroup.dropBackground": "{{accent}}30",
    "editorGroup.emptyBackground": "{{background}}",
    "editorGroup.focusedEmptyBorder": "{{accent}}50",
    "editorGroup.dropIntoPromptForeground": "{{foreground}}",
    "editorGroup.dropIntoPromptBackground": "{{backgroundPanel}}",
    "editorGroup.dropIntoPromptBorder": "{{accent}}50",
    "editorPane.background": "{{background}}",
    "sideBySideEditor.horizontalBorder": "{{accent}}20",
    "sideBySideEditor.verticalBorder": "{{accent}}20",

    // ─── Panel ───────────────────────────────────────────────
    "panel.background": "{{backgroundPanel}}",
    "panel.border": "{{accent}}20",
    "panel.dropBorder": "{{accent}}",
    "panelTitle.activeForeground": "{{accent}}",
    "panelTitle.inactiveForeground": "{{muted}}80",
    "panelTitle.activeBorder": "{{accent}}",
    "panelTitle.border": "{{accent}}20",
    "panelInput.border": "{{accent}}50",
    "panelSection.border": "{{accent}}20",
    "panelSection.dropBackground": "{{accent}}30",
    "panelSectionHeader.background": "{{sidebarHeaderBg|background}}80",
    "panelSectionHeader.foreground": "{{accent}}",
    "panelSectionHeader.border": "{{accent}}20",
    "panelStickyScroll.background": "{{backgroundPanel}}",
    "panelStickyScroll.border": "{{accent}}20",
    "panelStickyScroll.shadow": "{{shadow}}30",
    "panelTitleBadge.background": "{{badge|accent}}",
    "panelTitleBadge.foreground": "{{foreground}}",
    "outputView.background": "{{backgroundPanel}}",
    "outputViewStickyScroll.background": "{{backgroundPanel}}",

    // ─── Terminal ────────────────────────────────────────────
    "terminal.background": "{{background}}",
    "terminal.foreground": "{{foreground}}",
    "terminal.border": "{{accent}}20",
    "terminal.ansiBlack": "{{terminal.black}}",
    "terminal.ansiRed": "{{terminal.red}}",
    "terminal.ansiGreen": "{{terminal.green}}",
    "terminal.ansiYellow": "{{terminal.yellow}}",
    "terminal.ansiBlue": "{{terminal.blue}}",
    "terminal.ansiMagenta": "{{terminal.magenta}}",
    "terminal.ansiCyan": "{{terminal.cyan}}",
    "terminal.ansiWhite": "{{terminal.white}}",
    "terminal.ansiBrightBlack": "{{terminal.brightBlack}}",
    "terminal.ansiBrightRed": "{{terminal.brightRed}}",
    "terminal.ansiBrightGreen": "{{terminal.brightGreen}}",
    "terminal.ansiBrightYellow": "{{terminal.brightYellow}}",
    "terminal.ansiBrightBlue": "{{terminal.brightBlue}}",
    "terminal.ansiBrightMagenta": "{{terminal.brightMagenta}}",
    "terminal.ansiBrightCyan": "{{terminal.brightCyan}}",
    "terminal.ansiBrightWhite": "{{terminal.brightWhite}}",
    "terminal.selectionBackground": "{{accent}}50",
    "terminal.selectionForeground": "{{foreground}}",
    "terminal.inactiveSelectionBackground": "{{accent}}30",
    "terminal.findMatchBackground": "{{findMatch|accent}}80",
    "terminal.findMatchBorder": "{{findMatchBorder|accent}}",
    "terminal.findMatchHighlightBackground": "{{findMatch|accent}}50",
    "terminal.findMatchHighlightBorder": "{{findMatchBorder|accent}}80",
    "terminal.hoverHighlightBackground": "{{accent}}30",
    "terminal.dropBackground": "{{accent}}30",
    "terminal.tab.activeBorder": "{{accent}}",
    "terminal.initialHintForeground": "{{muted}}80",
    "terminalCursor.foreground": "{{accent}}",
    "terminalCursor.background": "{{background}}",
    "terminalCommandDecoration.defaultBackground": "{{accent}}50",
    "terminalCommandDecoration.successBackground": "{{terminalSuccess|success}}80",
    "terminalCommandDecoration.errorBackground": "{{terminalError|terminal.red}}80",
    "terminalOverviewRuler.cursorForeground": "{{accent}}",
    "terminalOverviewRuler.findMatchForeground": "{{accent}}CC",
    "terminalOverviewRuler.border": "{{accent}}20",
    "terminalStickyScroll.background": "{{backgroundPanel}}",
    "terminalStickyScroll.border": "{{accent}}20",
    "terminalStickyScrollHover.background": "{{backgroundHover}}",
    "terminalCommandGuide.foreground": "{{accent}}30",
    "terminalSymbolIcon.aliasForeground": "{{accent}}",
    "terminalSymbolIcon.branchForeground": "{{success}}",
    "terminalSymbolIcon.commitForeground": "{{accent}}",
    "terminalSymbolIcon.flagForeground": "{{warning}}",
    "terminalSymbolIcon.optionForeground": "{{foreground}}",
    "terminalSymbolIcon.optionValueForeground": "{{string}}",
    "terminalSymbolIcon.methodForeground": "{{function}}",
    "terminalSymbolIcon.argumentForeground": "{{constant}}",
    "terminalSymbolIcon.inlineSuggestionForeground": "{{muted}}80",
    "terminalSymbolIcon.fileForeground": "{{muted}}",
    "terminalSymbolIcon.folderForeground": "{{accent}}",
    "terminalSymbolIcon.pullRequestDoneForeground": "{{success}}",
    "terminalSymbolIcon.pullRequestForeground": "{{accent}}",
    "terminalSymbolIcon.remoteForeground": "{{keyword}}",
    "terminalSymbolIcon.stashForeground": "{{modified|function}}",
    "terminalSymbolIcon.symbolText": "{{foreground}}",
    "terminalSymbolIcon.symbolicLinkFileForeground": "{{accent}}80",
    "terminalSymbolIcon.symbolicLinkFolderForeground": "{{accent}}80",
    "terminalSymbolIcon.tagForeground": "{{keyword}}",

    // ─── Buttons ─────────────────────────────────────────────
    "button.background": "{{button|accent}}",
    "button.foreground": "{{foreground}}",
    "button.border": "{{button|accent}}00",
    "button.separator": "{{foreground}}40",
    "button.hoverBackground": "{{buttonHover|accentHover}}",
    "button.secondaryForeground": "{{foreground}}",
    "button.secondaryBackground": "{{backgroundElevated}}",
    "button.secondaryHoverBackground": "{{backgroundHover}}",
    "button.secondaryBorder": "{{accent}}50",

    // ─── Checkbox & Radio ────────────────────────────────────
    "checkbox.background": "{{backgroundInput}}",
    "checkbox.foreground": "{{accent}}",
    "checkbox.border": "{{accent}}50",
    "checkbox.selectBackground": "{{backgroundInput}}",
