    "symbolIcon.colorForeground": "{{accent}}",
    "symbolIcon.constantForeground": "{{constant}}",
    "symbolIcon.constructorForeground": "{{function}}",
    "symbolIcon.enumeratorForeground": "{{keyword}}",
    "symbolIcon.enumeratorMemberForeground": "{{constant}}",
    "symbolIcon.eventForeground": "{{warning}}",
    "symbolIcon.fieldForeground": "{{accent}}",
    "symbolIcon.fileForeground": "{{muted}}",
    "symbolIcon.folderForeground": "{{accent}}",
    "symbolIcon.functionForeground": "{{function}}",
    "symbolIcon.interfaceForeground": "{{keyword}}",
    "symbolIcon.keyForeground": "{{accent}}",
    "symbolIcon.keywordForeground": "{{keyword}}",
    "symbolIcon.methodForeground": "{{function}}",
    "symbolIcon.moduleForeground": "{{accent}}",
    "symbolIcon.namespaceForeground": "{{accent}}",
    "symbolIcon.nullForeground": "{{muted}}80",
    "symbolIcon.numberForeground": "{{constant}}",
    "symbolIcon.objectForeground": "{{accent}}",
    "symbolIcon.operatorForeground": "{{function}}",
    "symbolIcon.packageForeground": "{{accent}}",
    "symbolIcon.propertyForeground": "{{foreground}}",
    "symbolIcon.referenceForeground": "{{accent}}",
    "symbolIcon.snippetForeground": "{{string}}",
    "symbolIcon.stringForeground": "{{string}}",
    "symbolIcon.structForeground": "{{keyword}}",
    "symbolIcon.textForeground": "{{foreground}}",
    "symbolIcon.typeParameterForeground": "{{keyword}}",
    "symbolIcon.unitForeground": "{{constant}}",
    "symbolIcon.variableForeground": "{{foreground}}",

    // ─── Extensions ──────────────────────────────────────────
    "extensionButton.prominentForeground": "{{foreground}}",
    "extensionButton.prominentBackground": "{{accent}}",
    "extensionButton.prominentHoverBackground": "{{accentHover}}",
    "extensionButton.background": "{{accent}}",
    "extensionButton.foreground": "{{foreground}}",
    "extensionButton.hoverBackground": "{{accentHover}}",
    "extensionButton.separator": "{{foreground}}40",
    "extensionBadge.remoteBackground": "{{accent}}",
    "extensionBadge.remoteForeground": "{{foreground}}",
    "extensionIcon.starForeground": "{{warning}}",
    "extensionIcon.verifiedForeground": "{{success}}",
    "extensionIcon.preReleaseForeground": "{{accent}}",
    "extensionIcon.sponsorForeground": "{{keyword}}",
    "extensionIcon.privateForeground": "{{muted}}80",
    "extensionButton.border": "{{accent}}00",
    "mcpIcon.starForeground": "{{warning}}",

    // ─── Charts ──────────────────────────────────────────────
    "charts.foreground": "{{foreground}}",
    "charts.lines": "{{muted}}80",
    "charts.red": "{{error}}",
    "charts.blue": "{{accent}}",
    "charts.yellow": "{{warning}}",
    "charts.orange": "{{constant}}",
    "charts.green": "{{success}}",
    "charts.purple": "{{keyword}}",

    // ─── Markdown alerts ─────────────────────────────────────
    "markdownAlert.note.foreground": "{{info}}",
    "markdownAlert.tip.foreground": "{{success}}",
    "markdownAlert.important.foreground": "{{keyword}}",
    "markdownAlert.warning.foreground": "{{warning}}",
    "markdownAlert.caution.foreground": "{{error}}",

    // ─── Agent session ───────────────────────────────────────
    "agentSessionReadIndicator.foreground": "{{accent}}",
    "agentStatusIndicator.background": "{{accent}}",

    // ─── Action bar ──────────────────────────────────────────
    "actionBar.toggledBackground": "{{accent}}40",

    // ─── Ports ───────────────────────────────────────────────
    "ports.iconRunningProcessForeground": "{{success}}",

    // ─── Comments view ───────────────────────────────────────
    "commentsView.resolvedIcon": "{{success}}",
    "commentsView.unresolvedIcon": "{{warning}}"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{commentToken}}"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Colors",
      "scope": ["constant.other.color"],
      "settings": {
        "foreground": "{{accent}}"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "{{error}}"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "Operator, Misc",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "punctuation",
        "meta.tag",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "{{tag|keyword}}"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": ["meta.block variable.other"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": ["support.other.variable", "string.other.link"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "variable.parameter",
        "keyword.other.unit",
        "keyword.other"
      ],
      "settings": {
        "foreground": "{{constant}}"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "{{string}}"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Entity Types",
      "scope": ["support.type"],
      "settings": {
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Language methods",
      "scope": ["variable.language"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": ["entity.name.method.js"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{function}}"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{htmlAttribute|function}}"
      }
    },
    {
      "name": "CSS Classes",
      "scope": ["entity.other.attribute-name.class"],
      "settings": {
        "foreground": "{{cssClass|function}}"
      }
    },
    {
      "name": "CSS ID's",
      "scope": ["source.sass keyword.control"],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "{{added|success}}"
      }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "{{error}}"
      }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "{{modified|function}}"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "{{regex|success}}"
      }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "{{regex|success}}"
      }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{function}}"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "{{accent}}"
      }
    },
    {
      "name": "JSON Key - Level 1",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "{{jsonLevel1|function}}"
      }
    },
    {
      "name": "JSON Key - Level 2",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "{{string}}"
      }
    },
    {
      "name": "JSON Key - Level 3",
      "scope": [
        "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "{{jsonLevel3|constant}}"
      }
    },
    {
      "name": "Markdown - Plain",
      "scope": [
        "text.html.markdown",
        "punctuation.definition.list_item.markdown"
      ],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline",
      "scope": ["text.html.markdown markup.inline.raw.markdown"],
      "settings": {
        "foreground": "{{markdownRaw|constant}}"
      }
    },
    {
      "name": "Markdown - Markup Raw Inline Punctuation",
      "scope": [
        "text.html.markdown markup.inline.raw.markdown punctuation.definition.raw.markdown"
      ],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Markdown - Heading",
      "scope": [
        "markdown.heading",
        "markup.heading | markup.heading entity.name",
        "markup.heading.markdown punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "{{accent}}"
      }
    },
    {
      "name": "Markup - Italic",
      "scope": ["markup.italic"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "Markup - Bold",
      "scope": ["markup.bold", "markup.bold string"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "Markup - Bold-Italic",
      "scope": [
        "markup.bold markup.italic",
        "markup.italic markup.bold",
        "markup.quote markup.bold",
        "markup.bold markup.italic string",
        "markup.italic markup.bold string",
        "markup.quote markup.bold string"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "Markup - Underline",
      "scope": ["markup.underline"],
      "settings": {
        "fontStyle": "underline",
        "foreground": "{{string}}"
      }
    },
    {
      "name": "Markdown - Blockquote",
      "scope": ["markup.quote punctuation.definition.blockquote.markdown"],
      "settings": {
        "foreground": "{{blockquote|comment}}"
      }
    },
    {
      "name": "Markup - Quote",
      "scope": ["markup.quote"],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown - Link",
      "scope": ["string.other.link.title.markdown"],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Markdown - Link Description",
      "scope": ["string.other.link.description.title.markdown"],
      "settings": {
        "foreground": "{{keyword}}"
      }
    },
    {
      "name": "Markdown - Link Anchor",
      "scope": ["constant.other.reference.link.markdown"],
      "settings": {
        "foreground": "{{string}}"
      }
    },
    {
      "name": "Markup - Raw Block",
      "scope": ["markup.raw.block"],
      "settings": {
        "foreground": "{{markdownRaw|constant}}"
      }
    },
    {
      "name": "Markdown - Raw Block Fenced",
      "scope": ["markup.raw.block.fenced.markdown"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Markdown - Fenced Code Block",
      "scope": ["punctuation.definition.fenced.markdown"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Markdown - Fenced Code Block Variable",
      "scope": [
        "markup.raw.block.fenced.markdown",
        "variable.language.fenced.markdown",
        "punctuation.section.class.end"
      ],
      "settings": {
        "foreground": "{{foreground}}"
      }
    },
    {
      "name": "Markdown - Fenced Language",
      "scope": ["variable.language.fenced.markdown"],
      "settings": {
        "foreground": "{{function}}"
      }
    },
    {
      "name": "Markdown - Separator",
      "scope": ["meta.separator"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "{{accent}}"
      }
    },
    {
      "name": "Markup - Table",
      "scope": ["markup.table"],
      "settings": {
        "foreground": "{{foreground}}"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "enumMember": "{{constant}}",
    "variable.constant": "{{constant}}",
    "variable.defaultLibrary": "{{keyword}}",
    "variable.readonly": "{{foreground}}",
    "property.readonly": "{{constant}}",
    "parameter": "{{foreground}}",
    "type": { "foreground": "{{keyword}}", "italic": true },
    "interface": { "foreground": "{{keyword}}", "italic": true },
    "enum": "{{keyword}}",
    "namespace": "{{accent}}",
    "decorator": "{{keyword}}",
    "variable:dart": "{{foreground}}",
    "property:dart": "{{function}}",
    "annotation:dart": "{{keyword}}",
    "parameter.label:dart": "{{foreground}}"
  }
}
